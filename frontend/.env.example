# Copy this file to .env and fill in your Azure values before running
# `npm run build`. See ../DEPLOY_ENV_VARS.md for the full reference.

# ───────────────────────────────────────────────────────────────────────────
# Azure OpenAI (chat + embeddings)
# ───────────────────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# Either a deployment name (URL is built from AZURE_OPENAI_ENDPOINT)
# or a full embeddings URL including ?api-version=...
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Optional: separate API key if embeddings live on another Azure resource.
# Falls back to AZURE_OPENAI_API_KEY when unset.
# AZURE_OPENAI_EMBEDDING_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Azure transcribe (Whisper / gpt-4o-transcribe)
# IMPORTANT: URL must end with /audio/transcriptions (NOT /audio/translations).
# ───────────────────────────────────────────────────────────────────────────
TRANSCRIPTION_AZ_ENDPOINT=
TRANSCRIPTION_AZ_MODEL=
TRANSCRIPTION_API_KEY=
